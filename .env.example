# =============================================================================
# Minestack AI Architect (PRD EDITOR) — Vercel Environment Variables
# Copy to Vercel Project → Settings → Environment Variables
# JANGAN commit file .env yang berisi nilai asli.
# =============================================================================

# --- Auth (WAJIB) ---
# Password & email admin HANYA di server, tidak pernah di frontend/GitHub
ADMIN_EMAIL=anda@email.com
ADMIN_PASSWORD=ganti-password-kuat-disini
ADMIN_NAME=Admin Minestack

# Secret untuk tanda tangan session JWT-like (min 16 karakter, acak)
# Generate: openssl rand -hex 32
SESSION_SECRET=ganti-dengan-string-acak-panjang-min-32-char
SESSION_TTL_HOURS=72

# User tambahan (opsional) — JSON array, tanpa spasi bermasalah di Vercel UI
# AUTH_USERS=[{"email":"user@email.com","password":"UserPass123","name":"User Demo","role":"user"}]
AUTH_USERS=

# --- AI (WAJIB untuk generate blueprint) ---
# API key HANYA di server — browser tidak pernah melihat nilai ini
AI_API_KEY=sk_portal_ganti_dengan_kunci_anda
AI_BASE_URL=https://siaptuan.my.id/v1
AI_MODEL=combo1

# true = wajib login (Bearer session) sebelum /api/ai
AI_REQUIRE_AUTH=true

# Opsional
APP_NAME=Minestack AI Architect
